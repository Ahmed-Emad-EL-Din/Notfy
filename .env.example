# RelaySignal Environment Variables
# Copy the contents of this file directly into Netlify's "Import Environment Variables" text box!

# 1. MongoDB Database URI
VITE_MONGODB_URI=

# 3. Cloudinary Media Storage
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=


# 4. Web-Push VAPID Keys (For Background Offline Push Notifications)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your-email@example.com

# 6. Firebase Client Config (For Frontend Auth - Google & Email login)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# 7. Firebase Admin Key (For Backend Auth Token Decoding - Netlify Functions)
VITE_FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT={}
